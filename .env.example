# Database (Supabase Postgres, Tokyo)
DATABASE_URL=postgresql://user:pass@db.host.supabase.co:5432/postgres

# Upstash Redis (legacy KV — monitor cache, stats counters, error log)
tebiq_KV_REST_API_URL=
tebiq_KV_REST_API_TOKEN=

# Admin
ADMIN_KEY=change-me-to-a-long-random-string

# Cron auth (Vercel Cron sets this Authorization header)
CRON_SECRET=change-me-to-a-long-random-string

# AWS Bedrock (Claude Haiku, Tokyo target)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
