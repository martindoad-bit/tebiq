# Database (Supabase Postgres, Tokyo)
DATABASE_URL=postgresql://user:pass@db.host.supabase.co:5432/postgres

# Upstash Redis (legacy KV — monitor cache, stats counters, error log)
tebiq_KV_REST_API_URL=
tebiq_KV_REST_API_TOKEN=

# Admin
ADMIN_KEY=change-me-to-a-long-random-string

# Cron auth (Vercel Cron sets this Authorization header)
CRON_SECRET=change-me-to-a-long-random-string

# AWS Bedrock (Claude Haiku, Tokyo target)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1

# Stripe (server)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe (client — must be NEXT_PUBLIC_ for browser bundle)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe price IDs (created in Stripe Dashboard — see BLOCK2_REPORT.md)
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_MATERIAL_PACKAGE=price_...
STRIPE_PRICE_EXPERT_CONSULTATION=price_...
# Optional: coupon ID for first-month ¥1 promotion (basic_monthly only)
STRIPE_COUPON_FIRST_MONTH=
# Public site URL for Stripe success / cancel / portal return URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email — visa expiry reminders, etc.)
# Get one at https://resend.com — domain tebiq.jp must be verified
# so that "noreply@tebiq.jp" passes SPF/DKIM.
RESEND_API_KEY=re_...
